# SkyLens Backend Environment Variables

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/skylens

# Server
PORT=3000

# Claude API
CLAUDE_API_KEY=sk-ant-your-api-key-here

# Cloudflare R2 (for offline pack storage)
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=skylens-packs
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Supabase (for auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Logging
RUST_LOG=info,skylens_backend=debug
